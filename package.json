{
  "name": "qianqian",
  "version": "1.0.0",
  "description": "AI 能力资产管理中枢 - 跨平台 AI 资产同步工具",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "acl": "bin/cli.js",
    "qianqian": "bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test tests/**/*.test.js",
    "test:watch": "node --test --watch dist/**/*.test.js",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "ai",
    "cursor",
    "opencode",
    "claude-code",
    "prompt",
    "skill",
    "agent",
    "sync",
    "cli"
  ],
  "author": "codertony",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codertony/qianqian.git"
  },
  "bugs": {
    "url": "https://github.com/codertony/qianqian/issues"
  },
  "homepage": "https://github.com/codertony/qianqian#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "axios": "^1.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "diff": "^8.0.3",
    "glob": "^10.3.0",
    "inquirer": "^9.2.0",
    "js-yaml": "^4.1.1",
    "openai": "^6.25.0",
    "ora": "^8.0.0",
    "picocolors": "^1.1.1",
    "simple-git": "^3.32.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/inquirer": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.34",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "bun-types": "latest",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3"
  },
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  }
}
